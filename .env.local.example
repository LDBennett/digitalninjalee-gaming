# Supabase - get these from your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=publishable-key

# RAWG - https://rawg.io/apidocs
RAWG_API_KEY=your-rawg-api-key

# IGDB (via Twitch) - https://api-docs.igdb.com/#getting-started
# These are Twitch developer app credentials — same thing as "IGDB credentials"
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_CLIENT_SECRET=your-twitch-client-secret

# Supabase service role - only needed for admin scripts, never expose to client
# Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
